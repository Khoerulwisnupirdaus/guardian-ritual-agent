# ── Wallet ──
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
RPC_URL=https://rpc.ritualfoundation.org

# ── LLM Provider ──
# Options: openai, anthropic, gemini, openrouter
LLM_PROVIDER=openai
MODEL=claude-opus-4-8
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.zyloo.io/v1

# ── HuggingFace ──
HF_TOKEN=hf_your_token_here
HF_REPO_ID=your-username/your-dataset

# ── Agent Config ──
AGENT_PROMPT=
SALT=guardian-sentinel-v2
CLI_TYPE=5
FREQUENCY=2000
WINDOW_NUM_CALLS=5
ROLLOVER_THRESHOLD_BPS=5000
FUND_AMOUNT=0.1
